generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Watchlist {
  id String @id @default(uuid())

  userId  String
  animeId Int
  
  type String
  title String
  poster_url String


  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([userId, animeId])
}
